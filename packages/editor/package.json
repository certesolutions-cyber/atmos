{
  "name": "@atmos/editor",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./player": "./src/player-entry.ts",
    "./vite": {
      "types": "./vite-plugin.d.ts",
      "import": "./vite-plugin.mjs"
    }
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./player": {
        "types": "./dist/player-entry.d.ts",
        "import": "./dist/player-entry.js"
      },
      "./vite": {
        "types": "./vite-plugin.d.ts",
        "import": "./vite-plugin.mjs"
      }
    }
  },
  "files": ["dist", "!dist/__tests__", "vite-plugin.mjs", "vite-plugin.d.ts", "package.json", "README.md"],
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": { "optional": true }
  },
  "dependencies": {
    "@atmos/animation": "^0.1.0",
    "@atmos/assets": "^0.1.0",
    "@atmos/core": "^0.1.0",
    "@atmos/math": "^0.1.0",
    "@atmos/renderer": "^0.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "scripts": {
    "test": "vitest run"
  }
}
