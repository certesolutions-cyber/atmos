{
  "name": "@certe/atmos-editor",
  "description": "Browser-based Unity-style editor for the Atmos Engine — hierarchy, inspector, gizmos",
  "version": "0.8.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/certesolutions-cyber/atmos.git",
    "directory": "packages/editor"
  },
  "homepage": "https://github.com/certesolutions-cyber/atmos",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "editor",
    "game-engine",
    "webgpu",
    "scene-editor",
    "gizmo",
    "inspector",
    "atmos"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./player": "./src/player-entry.ts",
    "./vite": {
      "types": "./vite-plugin.d.ts",
      "import": "./vite-plugin.mjs",
      "require": "./vite-plugin.cjs"
    }
  },
  "publishConfig": {
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./player": {
        "types": "./dist/player-entry.d.ts",
        "import": "./dist/player-entry.js"
      },
      "./vite": {
        "types": "./vite-plugin.d.ts",
        "import": "./vite-plugin.mjs",
        "require": "./vite-plugin.cjs"
      }
    }
  },
  "files": [
    "dist",
    "!dist/__tests__",
    "vite-plugin.mjs",
    "vite-plugin.cjs",
    "vite-plugin.d.ts",
    "bin",
    "package.json",
    "README.md",
    "LICENCE"
  ],
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "dependencies": {
    "@certe/atmos-animation": "^0.8.1",
    "@certe/atmos-assets": "^0.8.1",
    "@certe/atmos-core": "^0.8.1",
    "@certe/atmos-math": "^0.8.1",
    "@certe/atmos-renderer": "^0.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "bin": {
    "atmos-init": "./bin/atmos-init.mjs"
  },
  "scripts": {
    "test": "vitest run"
  }
}
